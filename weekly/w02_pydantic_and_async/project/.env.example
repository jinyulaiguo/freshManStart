# 外部 HTTP 请求超时时间（秒）
HTTP_TIMEOUT=5.0

# 异步重试相关配置
MAX_RETRIES=3
RETRY_BASE_DELAY=0.5

# 外部 API 地址（无 API Key 真实服务）
WEATHER_API_BASE=https://wttr.in
EXCHANGE_API_BASE=https://api.frankfurter.app

# 日志输出级别与文件路径配置
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=tool_runner.log

# 批量执行最大并发池大小限制
MAX_CONCURRENT_TOOLS=10
