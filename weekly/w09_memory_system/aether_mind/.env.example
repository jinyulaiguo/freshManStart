# === LLM Client API Credentials ===
# 真实大模型凭证，请填写您的 MiniMax API Key 与 Endpoint 
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=abab6.5g-chat

# === Database Configuration ===
# 存储后端支持选择 'sqlite' 或 'postgres'
DB_BACKEND=sqlite

# === PostgreSQL Config (Required only if DB_BACKEND=postgres) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aether_mind

# === Vector Database Config ===
# Qdrant 物理服务主机和端口（若留空则自动开启本地轻量 :memory: 模式，无需本地部署）
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_API_KEY=
